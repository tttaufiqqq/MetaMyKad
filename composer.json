{
  "name": "metamykad/app",
  "description": "Pure PHP and MySQL scaffold for the MetaMyKad multimedia registry project.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "ext-fileinfo": "*",
    "ext-mbstring": "*",
    "ext-gd": "*",
    "ext-exif": "*"
  },
  "autoload": {
    "psr-4": {
      "MetaMyKad\\": "src/"
    },
    "files": [
      "src/Helpers/functions.php"
    ]
  },
  "scripts": {
    "deploy:folders": "php scripts/create-storage-folders.php",
    "deploy:check": "php scripts/check-deployment.php"
  }
}
